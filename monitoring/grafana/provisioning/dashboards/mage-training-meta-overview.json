{
  "id": null,
  "uid": "mage-training-meta-overview",
  "title": "Mage Training - Meta Overview",
  "tags": ["mage", "rl", "mtgrl", "meta", "profiles"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "profile",
        "type": "query",
        "label": "Profile",
        "datasource": "Prometheus",
        "query": "label_values(mage_profile_training_episodes, profile)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "window",
        "type": "custom",
        "label": "Rolling Window",
        "query": "50,100,200,500",
        "current": {
          "selected": false,
          "text": "200",
          "value": "200"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Episodes/sec",
      "type": "stat",
      "targets": [
        {
          "expr": "clamp_min(sum(rate(mage_profile_training_episodes{profile=~\"$profile\"}[$__rate_interval])), 0)",
          "legendFormat": "eps",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "eps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 4 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Training Rows",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(mage_profile_training_episodes{profile=~\"$profile\"})",
          "legendFormat": "episodes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 }
    },
    {
      "id": 3,
      "title": "Mean Rolling Winrate",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(mage_profile_winrate_rolling{profile=~\"$profile\",window=\"$window\"})",
          "legendFormat": "winrate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.45 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 }
    },
    {
      "id": 4,
      "title": "Pending Train Episodes",
      "type": "stat",
      "targets": [
        {
          "expr": "max(gpu_service_pending_trains)",
          "legendFormat": "pending",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "red", "value": 48 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 }
    },
    {
      "id": 5,
      "title": "Train Service Time",
      "type": "stat",
      "targets": [
        {
          "expr": "max(gpu_service_train_service_recent_avg_ms)",
          "legendFormat": "ms",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1500 },
              { "color": "red", "value": 5000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 }
    },
    {
      "id": 6,
      "title": "Failures / Drops / VRAM Requeues",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(gpu_service_train_failures_total) + sum(gpu_service_train_tasks_dropped_total) + sum(gpu_service_train_vram_requeues_total)",
          "legendFormat": "bad events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 }
    },
    {
      "id": 7,
      "title": "Episodes/sec by Profile",
      "type": "timeseries",
      "targets": [
        {
          "expr": "clamp_min(rate(mage_profile_training_episodes{profile=~\"$profile\"}[$__rate_interval]), 0)",
          "legendFormat": "{{profile}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "eps",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 }
    },
    {
      "id": 8,
      "title": "Rolling Winrate by Profile",
      "type": "timeseries",
      "targets": [
        {
          "expr": "mage_profile_winrate_rolling{profile=~\"$profile\",window=\"$window\"}",
          "legendFormat": "{{profile}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.45 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 }
    },
    {
      "id": 9,
      "title": "Episodes by Profile",
      "type": "bargauge",
      "targets": [
        {
          "expr": "mage_profile_training_episodes{profile=~\"$profile\"}",
          "legendFormat": "{{profile}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 }
    },
    {
      "id": 10,
      "title": "Rolling Winrate by Deck",
      "type": "bargauge",
      "targets": [
        {
          "expr": "mage_profile_training_deck_winrate_rolling{profile=~\"$profile\",window=\"$window\"}",
          "legendFormat": "{{profile}} / {{rl_deck}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.45 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 }
    },
    {
      "id": 11,
      "title": "Value Accuracy by Profile",
      "type": "bargauge",
      "targets": [
        {
          "expr": "mage_profile_value_accuracy{profile=~\"$profile\"}",
          "legendFormat": "{{profile}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.45 },
              { "color": "green", "value": 0.55 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 }
    },
    {
      "id": 12,
      "title": "Episode Duration and Turns",
      "type": "timeseries",
      "targets": [
        {
          "expr": "mage_profile_episode_seconds_rolling_avg{profile=~\"$profile\",window=\"$window\"}",
          "legendFormat": "{{profile}} seconds",
          "refId": "A"
        },
        {
          "expr": "mage_profile_turns_rolling_avg{profile=~\"$profile\",window=\"$window\"}",
          "legendFormat": "{{profile}} turns",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 }
    },
    {
      "id": 13,
      "title": "Loss Components by Profile",
      "type": "timeseries",
      "targets": [
        {
          "expr": "mage_profile_training_loss{profile=~\"$profile\",component=~\"total|policy|value|entropy\"}",
          "legendFormat": "{{profile}} {{component}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 }
    },
    {
      "id": 14,
      "title": "Learner Backpressure",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gpu_service_pending_trains",
          "legendFormat": "pending train episodes",
          "refId": "A"
        },
        {
          "expr": "mage_actor_learner_queue_depth",
          "legendFormat": "actor learner queue",
          "refId": "B"
        },
        {
          "expr": "rate(gpu_service_train_enqueue_backpressure_wait_ms_total[$__rate_interval]) / 1000",
          "legendFormat": "producer wait sec/sec",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 }
    },
    {
      "id": 15,
      "title": "Learner Service and Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gpu_service_train_service_recent_avg_ms",
          "legendFormat": "service avg",
          "refId": "A"
        },
        {
          "expr": "gpu_service_train_latency_recent_avg_ms",
          "legendFormat": "queue-to-finish latency avg",
          "refId": "B"
        },
        {
          "expr": "gpu_service_train_batch_avg_steps",
          "legendFormat": "avg train steps",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "service avg" },
            "properties": [{ "id": "unit", "value": "ms" }]
          },
          {
            "matcher": { "id": "byName", "options": "queue-to-finish latency avg" },
            "properties": [{ "id": "unit", "value": "ms" }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 }
    },
    {
      "id": 16,
      "title": "GPU Safety Events",
      "type": "timeseries",
      "targets": [
        {
          "expr": "increase(gpu_service_train_failures_total[$__rate_interval])",
          "legendFormat": "train failures",
          "refId": "A"
        },
        {
          "expr": "increase(gpu_service_train_tasks_dropped_total[$__rate_interval])",
          "legendFormat": "dropped train episodes",
          "refId": "B"
        },
        {
          "expr": "increase(gpu_service_train_vram_requeues_total[$__rate_interval])",
          "legendFormat": "vram requeues",
          "refId": "C"
        },
        {
          "expr": "increase(mage_actor_learner_dropped_total[$__rate_interval])",
          "legendFormat": "actor learner drops",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 }
    },
    {
      "id": 17,
      "title": "JVM Memory",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 * mage_jvm_memory_used_bytes / mage_jvm_memory_max_bytes",
          "legendFormat": "heap used %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 }
    },
    {
      "id": 18,
      "title": "Matchup Rolling Winrates",
      "type": "table",
      "targets": [
        {
          "expr": "mage_profile_training_matchup_winrate_rolling{profile=~\"$profile\",window=\"$window\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "{{profile}} {{rl_deck}} vs {{opp_deck}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 45 }
    }
  ]
}
